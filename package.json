{
    "name": "@nevillegallimore/utils",
    "description": "Library of shared utility functions",
    "author": "Neville Gallimore <neville.gallimore@gmail.com>",
    "license": "ISC",
    "homepage": "https://github.com/nevillegallimore/utils#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/nevillegallimore/utils.git"
    },
    "bugs": {
        "url": "https://github.com/nevillegallimore/utils/issues"
    },
    "version": "0.0.0-development",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/@nevillegallimore"
    },
    "devDependencies": {
        "@babel/core": "^7.16.7",
        "@types/chai": "^4.3.0",
        "@types/mocha": "^9.0.0",
        "babel-loader": "^8.2.3",
        "chai": "^4.3.4",
        "commitizen": "^4.2.4",
        "cross-env": "^7.0.3",
        "cz-conventional-changelog": "^3.3.0",
        "mocha": "^9.1.3",
        "move-cli": "^2.0.0",
        "rimraf": "^3.0.2",
        "semantic-release": "^18.0.1",
        "ts-node": "^10.4.0",
        "typescript": "^4.5.4",
        "webpack": "^5.65.0",
        "webpack-cli": "^4.9.1"
    },
    "scripts": {
        "build": "npm run clean && npm run build:esm && npm run build:umd",
        "build:esm": "tsc && move-cli ./dist/index.js ./dist/index.esm.js",
        "build:umd": "webpack --config ./webpack.config.js",
        "clean": "rimraf ./dist",
        "commit": "git-cz",
        "test": "cross-env TS_NODE_PROJECT='./tsconfig.spec.json' mocha -r ts-node/register ./src/**/*.spec.ts",
        "semantic-release": "semantic-release --branches main"
    },
    "dependencies": {}
}
